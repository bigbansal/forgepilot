# ── Manch Backend — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── App ───────────────────────────────────────────────────────────────────────
MANCH_ENV=dev
MANCH_HOST=0.0.0.0
MANCH_PORT=8080
MANCH_LOG_LEVEL=INFO
MANCH_API_PREFIX=/api/v1
MANCH_PUBLIC_BASE_URL=http://localhost:8212

# ── Database ──────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml dev credentials.
MANCH_DATABASE_URL=postgresql+psycopg://manch:manch_secret@localhost:5545/manch

# ── OpenSandbox ───────────────────────────────────────────────────────────────
MANCH_OPENSANDBOX_BASE_URL=http://localhost:3201
MANCH_OPENSANDBOX_API_KEY=
MANCH_OPENSANDBOX_IMAGE_URI=manch/sandbox-runtime:local
MANCH_OPENSANDBOX_TIMEOUT_SECONDS=1800
MANCH_OPENSANDBOX_READY_TIMEOUT_SECONDS=120
MANCH_OPENSANDBOX_REQUEST_TIMEOUT_SECONDS=30
MANCH_OPENSANDBOX_USE_SERVER_PROXY=true

# ── Task Execution ────────────────────────────────────────────────────────────
MANCH_MAX_STEPS_PER_TASK=30
MANCH_ALLOW_HIGH_RISK_COMMANDS=false

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
MANCH_SECRET_KEY=
MANCH_ACCESS_TOKEN_EXPIRE_MINUTES=15
MANCH_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Provider Keys ─────────────────────────────────────────────────────────
# At least one provider key is required for agent execution.
GEMINI_API_KEY=
MANCH_GEMINI_API_KEY=
OPENAI_API_KEY=
MANCH_OPENAI_API_KEY=
MANCH_ANTHROPIC_API_KEY=
