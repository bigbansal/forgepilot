# Root docker-compose overrides for local development.
# Copy to .env at repository root before running startup.sh.

# Database container credentials used by docker-compose and backend service URL.
MANCH_POSTGRES_DB=manch
MANCH_POSTGRES_USER=manch
MANCH_POSTGRES_PASSWORD=manch_secret

# RabbitMQ management credentials.
MANCH_RABBITMQ_USER=manch
MANCH_RABBITMQ_PASSWORD=manch_secret

# Host ports (optional overrides)
MANCH_DB_PORT=5545
